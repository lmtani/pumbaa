  "submittedFiles": {
    "workflow": "version 1.0\n\n## Convert a pair of FASTQ files into an unmapped BAM (uBAM), the first step of\n## most short-read alignment pipelines. Uses Picard FastqToSam.\n\nworkflow FastqToUnmappedBam {\n  input {\n    File r1_fastq\n    File r2_fastq\n    String sample_name\n    String read_group = \"rg1\"\n  }\n\n  call FastqToSam {\n    input:\n      r1_fastq = r1_fastq,\n      r2_fastq = r2_fastq,\n      sample_name = sample_name,\n      read_group = read_group\n  }\n\n  output {\n    File unmapped_bam = FastqToSam.unmapped_bam\n  }\n\n  parameter_meta {\n    r1_fastq: \"Gzipped FASTQ with the forward (R1) reads.\"\n    r2_fastq: \"Gzipped FASTQ with the reverse (R2) reads.\"\n    sample_name: \"Sample name stored in the SM read-group field.\"\n    read_group: \"Read-group identifier (ID).\"\n  }\n}\n\ntask FastqToSam {\n  input {\n    File r1_fastq\n    File r2_fastq\n    String sample_name\n    String read_group\n    String docker = \"broadinstitute/picard:2.27.4\"\n    Int memory_mb = 3500\n  }\n\n  Int java_heap_mb = memory_mb - 500\n  String output_basename = sub(sub(basename(r1_fastq), \".fastq.gz$\", \"\"), \".fq.gz$\", \"\")\n\n  command <<<\n    set -e\n    java -Xmx~{java_heap_mb}m -jar /usr/picard/picard.jar FastqToSam \\\n      -FASTQ \"~{r1_fastq}\" \\\n      -FASTQ2 \"~{r2_fastq}\" \\\n      -READ_GROUP_NAME \"~{read_group}\" \\\n      -SAMPLE_NAME \"~{sample_name}\" \\\n      -LIBRARY_NAME \"UNKNOWN\" \\\n      -PLATFORM \"ILLUMINA\" \\\n      -OUTPUT \"~{output_basename}.unmapped.bam\"\n  >>>\n\n  runtime {\n    docker: docker\n    cpu: 1\n    memory: \"~{memory_mb} MiB\"\n    disks: \"local-disk 10 HDD\"\n  }\n\n  output {\n    File unmapped_bam = \"~{output_basename}.unmapped.bam\"\n  }\n}\n",
    "root": "",
    "options": "{\n\n}",
    "inputs": "{\"FastqToUnmappedBam.r1_fastq\":\"__FIXROOT__/data/NA12878_clean_R1.fq.gz\",\"FastqToUnmappedBam.r2_fastq\":\"__FIXROOT__/data/NA12878_clean_R2.fq.gz\",\"FastqToUnmappedBam.sample_name\":\"NA12878\"}",
    "workflowUrl": "",
