  "submittedFiles": {
    "workflow": "version 1.0\n\n## Compress a BAM into the reference-based CRAM format, which stores aligned\n## reads far more compactly. Uses samtools view -C.\n\nworkflow BamToCram {\n  input {\n    File input_bam\n    File ref_fasta\n    File ref_fasta_index\n    String output_basename\n  }\n\n  call ConvertToCram {\n    input:\n      input_bam = input_bam,\n      ref_fasta = ref_fasta,\n      ref_fasta_index = ref_fasta_index,\n      output_basename = output_basename\n  }\n\n  output {\n    File cram = ConvertToCram.output_cram\n    File cram_index = ConvertToCram.output_cram_index\n  }\n\n  parameter_meta {\n    input_bam: \"Coordinate-sorted BAM to compress.\"\n    ref_fasta: \"Reference FASTA the reads were aligned to (must match the BAM).\"\n    ref_fasta_index: \"The .fai index for ref_fasta.\"\n    output_basename: \"Basename for the output .cram/.crai files.\"\n  }\n}\n\ntask ConvertToCram {\n  input {\n    File input_bam\n    File ref_fasta\n    File ref_fasta_index\n    String output_basename\n    String docker = \"quay.io/biocontainers/samtools:1.21--h96c455f_1\"\n  }\n\n  command <<<\n    set -e -o pipefail\n    samtools view -C -T ~{ref_fasta} ~{input_bam} -o ~{output_basename}.cram\n    samtools index ~{output_basename}.cram\n  >>>\n\n  runtime {\n    docker: docker\n    cpu: 1\n    memory: \"1 GiB\"\n    disks: \"local-disk 10 HDD\"\n  }\n\n  output {\n    File output_cram = \"~{output_basename}.cram\"\n    File output_cram_index = \"~{output_basename}.cram.crai\"\n  }\n}\n",
    "root": "",
    "options": "{\n\n}",
    "inputs": "{\"BamToCram.input_bam\":\"__FIXROOT__/data/chrM.bam\",\"BamToCram.output_basename\":\"chrM\",\"BamToCram.ref_fasta\":\"__FIXROOT__/data/mito_genome.fasta\",\"BamToCram.ref_fasta_index\":\"__FIXROOT__/data/mito_genome.fasta.fai\"}",
    "workflowUrl": "",
    "labels": "{}"
  },
