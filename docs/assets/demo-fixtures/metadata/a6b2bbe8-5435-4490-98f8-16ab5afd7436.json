  "submittedFiles": {
    "workflow": "version 1.0\n\n## Block-compress and index a VCF, then compute summary statistics. Two tasks\n## chained (stats consumes the indexed VCF). Uses bcftools.\n\nworkflow VcfIndexAndStats {\n  input {\n    File input_vcf\n    String output_basename\n  }\n\n  call IndexVcf {\n    input:\n      input_vcf = input_vcf,\n      output_basename = output_basename\n  }\n\n  call StatsVcf {\n    input:\n      input_vcf = IndexVcf.out_vcf,\n      input_vcf_index = IndexVcf.out_vcf_index,\n      output_basename = output_basename\n  }\n\n  output {\n    File indexed_vcf = IndexVcf.out_vcf\n    File indexed_vcf_index = IndexVcf.out_vcf_index\n    File stats_report = StatsVcf.report\n  }\n\n  parameter_meta {\n    input_vcf: \"VCF (optionally gzipped) to index and summarize.\"\n    output_basename: \"Basename for the output files.\"\n  }\n}\n\ntask IndexVcf {\n  input {\n    File input_vcf\n    String output_basename\n    String docker = \"quay.io/biocontainers/bcftools:1.11--h7c999a4_0\"\n  }\n\n  command <<<\n    set -e\n    bcftools view -Oz -o ~{output_basename}.vcf.gz ~{input_vcf}\n    bcftools index --tbi ~{output_basename}.vcf.gz\n  >>>\n\n  runtime {\n    docker: docker\n    cpu: 1\n    memory: \"512 MiB\"\n    disks: \"local-disk 10 HDD\"\n  }\n\n  output {\n    File out_vcf = \"~{output_basename}.vcf.gz\"\n    File out_vcf_index = \"~{output_basename}.vcf.gz.tbi\"\n  }\n}\n\ntask StatsVcf {\n  input {\n    File input_vcf\n    File input_vcf_index\n    String output_basename\n    String docker = \"quay.io/biocontainers/bcftools:1.11--h7c999a4_0\"\n  }\n\n  command <<<\n    set -e\n    bcftools stats ~{input_vcf} > ~{output_basename}.stats.txt\n  >>>\n\n  runtime {\n    docker: docker\n    cpu: 1\n    memory: \"512 MiB\"\n    disks: \"local-disk 10 HDD\"\n  }\n\n  output {\n    File report = \"~{output_basename}.stats.txt\"\n  }\n}\n",
    "root": "",
    "options": "{\n\n}",
    "inputs": "{\"VcfIndexAndStats.input_vcf\":\"__FIXROOT__/data/NA12878.chr20.vcf.gz\",\"VcfIndexAndStats.output_basename\":\"NA12878.chr20\"}",
