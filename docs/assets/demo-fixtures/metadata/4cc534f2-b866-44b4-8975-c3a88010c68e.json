  "submittedFiles": {
    "workflow": "version 1.0\n\n## Decompress a CRAM back into a BAM. Uses samtools view -b, providing the same\n## reference the CRAM was encoded against.\n\nworkflow CramToBam {\n  input {\n    File input_cram\n    File ref_fasta\n    File ref_fasta_index\n    String output_basename\n  }\n\n  call ConvertToBam {\n    input:\n      input_cram = input_cram,\n      ref_fasta = ref_fasta,\n      ref_fasta_index = ref_fasta_index,\n      output_basename = output_basename\n  }\n\n  output {\n    File bam = ConvertToBam.output_bam\n    File bam_index = ConvertToBam.output_bam_index\n  }\n\n  parameter_meta {\n    input_cram: \"CRAM to decompress.\"\n    ref_fasta: \"Reference FASTA the CRAM was encoded against (must match).\"\n    ref_fasta_index: \"The .fai index for ref_fasta.\"\n    output_basename: \"Basename for the output .bam/.bai files.\"\n  }\n}\n\ntask ConvertToBam {\n  input {\n    File input_cram\n    File ref_fasta\n    File ref_fasta_index\n    String output_basename\n    String docker = \"quay.io/biocontainers/samtools:1.21--h96c455f_1\"\n  }\n\n  command <<<\n    set -e\n    samtools view -b -T ~{ref_fasta} ~{input_cram} -o ~{output_basename}.bam\n    samtools index ~{output_basename}.bam\n  >>>\n\n  runtime {\n    docker: docker\n    cpu: 1\n    memory: \"1 GiB\"\n    disks: \"local-disk 10 HDD\"\n  }\n\n  output {\n    File output_bam = \"~{output_basename}.bam\"\n    File output_bam_index = \"~{output_basename}.bam.bai\"\n  }\n}\n",
    "root": "",
    "options": "{\n\n}",
    "inputs": "{\"CramToBam.input_cram\":\"__FIXROOT__/data/NA12878.mitochondria.cram\",\"CramToBam.output_basename\":\"NA12878.mitochondria\",\"CramToBam.ref_fasta\":\"__FIXROOT__/data/Homo_sapiens_assembly38.chrM.fasta\",\"CramToBam.ref_fasta_index\":\"__FIXROOT__/data/Homo_sapiens_assembly38.chrM.fasta.fai\"}",
