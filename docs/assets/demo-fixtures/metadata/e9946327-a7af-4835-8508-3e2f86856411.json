  "submittedFiles": {
    "workflow": "version 1.0\n\n## Two-step alignment QC over a BAM: samtools flagstat (mapping summary) and\n## samtools stats (detailed metrics). Two tasks, so the call tree is richer in\n## the debug view.\n\nworkflow BamQualityCheck {\n  input {\n    File input_bam\n    String output_basename\n  }\n\n  call Flagstat {\n    input:\n      input_bam = input_bam,\n      output_basename = output_basename\n  }\n\n  call Stats {\n    input:\n      input_bam = input_bam,\n      output_basename = output_basename\n  }\n\n  output {\n    File flagstat_report = Flagstat.report\n    File stats_report = Stats.report\n  }\n\n  parameter_meta {\n    input_bam: \"BAM to summarize.\"\n    output_basename: \"Basename for the two report files.\"\n  }\n}\n\ntask Flagstat {\n  input {\n    File input_bam\n    String output_basename\n    String docker = \"quay.io/biocontainers/samtools:1.21--h96c455f_1\"\n  }\n\n  command <<<\n    set -e\n    samtools flagstat ~{input_bam} > ~{output_basename}.flagstat.txt\n  >>>\n\n  runtime {\n    docker: docker\n    cpu: 1\n    memory: \"512 MiB\"\n    disks: \"local-disk 10 HDD\"\n  }\n\n  output {\n    File report = \"~{output_basename}.flagstat.txt\"\n  }\n}\n\ntask Stats {\n  input {\n    File input_bam\n    String output_basename\n    String docker = \"quay.io/biocontainers/samtools:1.21--h96c455f_1\"\n  }\n\n  command <<<\n    set -e\n    samtools stats ~{input_bam} > ~{output_basename}.stats.txt\n  >>>\n\n  runtime {\n    docker: docker\n    cpu: 1\n    memory: \"512 MiB\"\n    disks: \"local-disk 10 HDD\"\n  }\n\n  output {\n    File report = \"~{output_basename}.stats.txt\"\n  }\n}\n",
    "root": "",
    "options": "{\n\n}",
    "inputs": "{\"BamQualityCheck.input_bam\":\"__FIXROOT__/data/chrM.bam\",\"BamQualityCheck.output_basename\":\"chrM\"}",
