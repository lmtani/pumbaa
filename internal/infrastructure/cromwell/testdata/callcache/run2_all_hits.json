{"workflowName":"VcfIndexAndStats","workflowProcessingEvents":[{"cromwellId":"cromid-b106fb2","description":"Finished","timestamp":"2026-07-18T11:06:45.779Z","cromwellVersion":"91"},{"cromwellId":"cromid-b106fb2","description":"PickedUp","timestamp":"2026-07-18T11:06:21.263Z","cromwellVersion":"91"}],"actualWorkflowLanguageVersion":"1.0","submittedFiles":{"workflow":"version 1.0\n\n## Block-compress and index a VCF, then compute summary statistics. Two tasks\n## chained (stats consumes the indexed VCF). Uses bcftools.\n\nworkflow VcfIndexAndStats {\n  input {\n    File input_vcf\n    String output_basename\n  }\n\n  call IndexVcf {\n    input:\n      input_vcf = input_vcf,\n      output_basename = output_basename\n  }\n\n  call StatsVcf {\n    input:\n      input_vcf = IndexVcf.out_vcf,\n      input_vcf_index = IndexVcf.out_vcf_index,\n      output_basename = output_basename\n  }\n\n  output {\n    File indexed_vcf = IndexVcf.out_vcf\n    File indexed_vcf_index = IndexVcf.out_vcf_index\n    File stats_report = StatsVcf.report\n  }\n\n  parameter_meta {\n    input_vcf: \"VCF (optionally gzipped) to index and summarize.\"\n    output_basename: \"Basename for the output files.\"\n  }\n}\n\ntask IndexVcf {\n  input {\n    File input_vcf\n    String output_basename\n    String docker = \"quay.io/biocontainers/bcftools:1.11--h7c999a4_0\"\n  }\n\n  command <<<\n    set -e\n    bcftools view -Oz -o ~{output_basename}.vcf.gz ~{input_vcf}\n    bcftools index --tbi ~{output_basename}.vcf.gz\n  >>>\n\n  runtime {\n    docker: docker\n    cpu: 1\n    memory: \"512 MiB\"\n    disks: \"local-disk 10 HDD\"\n  }\n\n  output {\n    File out_vcf = \"~{output_basename}.vcf.gz\"\n    File out_vcf_index = \"~{output_basename}.vcf.gz.tbi\"\n  }\n}\n\ntask StatsVcf {\n  input {\n    File input_vcf\n    File input_vcf_index\n    String output_basename\n    String docker = \"quay.io/biocontainers/bcftools:1.11--h7c999a4_0\"\n  }\n\n  command <<<\n    set -e\n    bcftools stats ~{input_vcf} > ~{output_basename}.stats.txt\n  >>>\n\n  runtime {\n    docker: docker\n    cpu: 1\n    memory: \"512 MiB\"\n    disks: \"local-disk 10 HDD\"\n  }\n\n  output {\n    File report = \"~{output_basename}.stats.txt\"\n  }\n}\n","root":"","options":"{\n\n}","inputs":"{\"VcfIndexAndStats.input_vcf\":\"/home/taniguti/github/lmtani/pumbaa/example/showcase/data/NA12878.chr20.vcf.gz\",\"VcfIndexAndStats.output_basename\":\"NA12878.chr20\"}","workflowUrl":"","labels":"{}"},"calls":{"VcfIndexAndStats.IndexVcf":[{"executionStatus":"Done","stdout":"/home/taniguti/github/lmtani/pumbaa/example/showcase/cromwell-executions/VcfIndexAndStats/ba8fc4dc-9bff-416f-b330-10154614b983/call-IndexVcf/execution/stdout","compressedDockerSize":72083447,"shardIndex":-1,"outputs":{"out_vcf_index":"/home/taniguti/github/lmtani/pumbaa/example/showcase/cromwell-executions/VcfIndexAndStats/ba8fc4dc-9bff-416f-b330-10154614b983/call-IndexVcf/cacheCopy/execution/NA12878.chr20.vcf.gz.tbi","out_vcf":"/home/taniguti/github/lmtani/pumbaa/example/showcase/cromwell-executions/VcfIndexAndStats/ba8fc4dc-9bff-416f-b330-10154614b983/call-IndexVcf/cacheCopy/execution/NA12878.chr20.vcf.gz"},"runtimeAttributes":{"maxRetries":"0","failOnStderr":"false","continueOnReturnCode":"0","docker":"quay.io/biocontainers/bcftools:1.11--h7c999a4_0"},"callCaching":{"allowResultReuse":true,"hashes":{"output count":"C81E728D9D4C2F636F067F89CC14862C","runtime attribute":{"docker":"5CF5ADB49E5191F0A1DA579CA8C9FB0E","continueOnReturnCode":"CFCD208495D565EF66E7DFF9F98764DA","failOnStderr":"68934A3E9455FA72420237EB05902327"},"output expression":{"File out_vcf_index":"6F8614DCFF6FA6B9673D60891E648AAA","File out_vcf":"3BE037CC96CE1D29EC506AF62BBDDDAF"},"input count":"ECCBC87E4B5CE2FE28308FD9F2A7BAF3","backend name":"509820290D57F333403F490DDE7316F4","command template":"94A353F002A219A742B02214A920582A","input":{"String output_basename":"7A6BE2B0057A7F4DE29BC1AC77497B5F","String docker":"6E5CA1E819BA223A974C66FF74978588","File input_vcf":"4